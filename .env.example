# Environment Variables for Docker Compose
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All values have sensible defaults for local development.

# ---------------------------------------------------------------------------
# Forgejo
# ---------------------------------------------------------------------------

# Admin credentials created on first Forgejo startup
FORGEJO_ADMIN_USER=helio
FORGEJO_ADMIN_PASSWORD=changeme

# Forgejo base URL (used by helix CLI inside the container)
FORGEJO_URL=http://forgejo:3000

# Optional: existing admin PAT (for helix-identity provisioning)
# If set, helix-identity uses this instead of admin BasicAuth.
# FORGEJO_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Chimera (AI Inference)
# ---------------------------------------------------------------------------

# Chimera base URL
CHIMERA_URL=http://chimera:8765

# OpenAI API key (optional — for OpenAI-backed models)
# OPENAI_API_KEY=

# OpenRouter API key (optional — for open-source models like owl-alpha)
# OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Helix Platform
# ---------------------------------------------------------------------------

# Path to known-friends.json (agent registry)
HELIX_KNOWN_FRIENDS=/root/.helix/known-friends.json

# SSH key directory for agent keys
HELIX_SSH_KEY_DIR=/root/.helix/keys

# State file for idempotency reconciliation
HELIX_STATE_PATH=/root/.helix/state.json

# ---------------------------------------------------------------------------
# Integration Test Configuration
# ---------------------------------------------------------------------------

# Set GOAWAY=1 to skip real network calls in CI
# GOAWAY=1
