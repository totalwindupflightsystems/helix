# Helix Environment Variables
# Copy to .env and fill in values

# Forgejo
FORGEJO_URL=http://localhost:3000
FORGEJO_ADMIN_USER=helio
FORGEJO_ADMIN_TOKEN=

# Chimera
CHIMERA_URL=http://localhost:8765
CHIMERA_API_KEY=

# Helix
HELIX_HOME=~/.helix
HELIX_LOG_LEVEL=info

# OpenRouter (for agent inference)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openrouter/owl-alpha

# LangFuse (observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# GitReins
GITREINS_MODEL=openrouter/owl-alpha
GITREINS_MAX_ITERATIONS=100
GITREINS_MAX_TIME=10m
