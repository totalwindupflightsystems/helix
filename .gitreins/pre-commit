#!/usr/bin/env bash
# GitReins Tier 1: Code quality checks (pre-commit)
# Checks 1-4 of the Helix 6-check harness
# Matches Helix spec Section 7.3
set -e
cd "$(git rev-parse --show-toplevel)"
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0
FAILED=0

# ── Check 1: Secrets scan (BLOCKING) ──
SECRET_PATTERNS='sk-[a-zA-Z0-9_-]{20,}|ghp_[a-zA-Z0-9]{36}|-----BEGIN (RSA |EC |OPENSSH )PRIVATE KEY-----|(OPENROUTER|DEEPSEEK|ZAI|ANTHROPIC)_API_KEY\s*=\s*\S'
PASS=1
while IFS= read -r file; do
  [ ! -f "$file" ] && continue
  git check-ignore -q "$file" 2>/dev/null && continue
  if grep -Pn "$SECRET_PATTERNS" "$file" 2>/dev/null; then
    echo "SECRET DETECTED in $file" >&2
    PASS=0
  fi
done <<< "$STAGED"
if [ $PASS -eq 0 ]; then
  echo "✗ [1/4] Secrets scan — FAIL" >&2
  FAILED=1
else
  echo "✓ [1/4] Secrets scan — PASS"
fi

# ── Check 2: Lint — Go (BLOCKING if .go staged) ──
GO_STAGED=$(echo "$STAGED" | grep '\.go$' || true)
if [ -n "$GO_STAGED" ]; then
  if command -v golangci-lint &>/dev/null; then
    golangci-lint run --timeout=30s ./... 2>&1 && echo "✓ [2/4] Lint (golangci-lint) — PASS" || { echo "✗ [2/4] Lint — FAIL" >&2; FAILED=1; }
  else
    go vet ./... 2>&1 && echo "✓ [2/4] Lint (go vet) — PASS" || { echo "✗ [2/4] Lint (go vet) — FAIL" >&2; FAILED=1; }
  fi
else
  echo "✓ [2/4] Lint — SKIP (no Go changes)"
fi

# ── Check 3: Tests — Go (BLOCKING if .go staged) ──
if [ -n "$(echo "$STAGED" | grep '\.go$' || true)" ]; then
  go test ./... -count=1 2>&1 && echo "✓ [3/4] Tests — PASS" || { echo "✗ [3/4] Tests — FAIL" >&2; FAILED=1; }
else
  echo "✓ [3/4] Tests — SKIP (no Go changes)"
fi

# ── Check 4: Build (BLOCKING if .go staged) ──
if [ -n "$(echo "$STAGED" | grep '\.go$' || true)" ]; then
  go build ./... 2>&1 && echo "✓ [4/4] Build — PASS" || { echo "✗ [4/4] Build — FAIL" >&2; FAILED=1; }
else
  echo "✓ [4/4] Build — SKIP (no Go changes)"
fi

if [ $FAILED -eq 1 ]; then
  echo ""
  echo "═══════════════════════════════════════════════" >&2
  echo "COMMIT BLOCKED: GitReins Tier 1 code checks failed" >&2
  echo "═══════════════════════════════════════════════" >&2
  exit 1
fi
