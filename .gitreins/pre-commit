#!/usr/bin/env bash
# GitReins Tier 1: Secrets (blocking) + Lint (Go) + Tests (Go)
# Generated for Helix monorepo — 2026-06-19
set -e
cd "$(git rev-parse --show-toplevel)"
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

# ── Stage 1: Secrets scan (BLOCKING) ──
SECRET_PATTERNS='sk-[a-zA-Z0-9_-]{20,}|ghp_[a-zA-Z0-9]{36}|-----BEGIN (RSA |EC |OPENSSH )PRIVATE KEY-----|(OPENROUTER|DEEPSEEK|ZAI|ANTHROPIC)_API_KEY\s*=\s*\S'
PASS=1
while IFS= read -r file; do
  [ ! -f "$file" ] && continue
  git check-ignore -q "$file" 2>/dev/null && continue
  if grep -Pn "$SECRET_PATTERNS" "$file" 2>/dev/null; then
    echo "SECRET DETECTED in $file" >&2
    PASS=0
  fi
done <<< "$STAGED"
if [ $PASS -eq 0 ]; then
  echo "COMMIT BLOCKED: secrets found" >&2
  exit 1
fi
echo "✓ GitReins Tier 1: Secrets scan — PASS"

# ── Stage 2: Lint — Go (non-blocking) ──
GO_STAGED=$(echo "$STAGED" | grep '\.go$' || true)
if [ -n "$GO_STAGED" ]; then
  if command -v golangci-lint &>/dev/null; then
    golangci-lint run --timeout=30s ./... 2>&1 || echo "⚠ GitReins Tier 1: Lint — WARNINGS (non-blocking)"
  else
    go vet ./... 2>&1 || echo "⚠ GitReins Tier 1: Lint (go vet) — WARNINGS (non-blocking)"
  fi
else
  echo "✓ GitReins Tier 1: Lint — SKIP (no Go changes)"
fi

# ── Stage 3: Tests — Go (non-blocking) ──
if [ -n "$(echo "$STAGED" | grep '\.go$' || true)" ]; then
  go test ./... -count=1 2>&1 || echo "⚠ GitReins Tier 1: Tests — FAIL (non-blocking)"
else
  echo "✓ GitReins Tier 1: Tests — SKIP (no Go changes)"
fi
